# ─── Application ──────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=replace_with_openssl_rand_hex_32

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=terraforge
POSTGRES_PASSWORD=terraforge_secret
POSTGRES_DB=terraforge_db
DATABASE_URL=postgresql://terraforge:terraforge_secret@db:5432/terraforge_db

# ─── HashiCorp Vault ──────────────────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_ROOT_TOKEN=root

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── AWS (never commit real keys) ─────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
